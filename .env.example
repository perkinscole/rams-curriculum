# Postgres connection string. For Neon: copy from your project's
# "Connection Details" page. Make sure it includes ?sslmode=require.
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# Random string used to sign session JWTs. Use a long random value in production.
JWT_SECRET=replace-with-a-long-random-string

# Optional: enables AI parsing of uploaded UBD documents and the Curriculum Connections feature.
ANTHROPIC_API_KEY=
